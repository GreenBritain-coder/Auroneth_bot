# Coolify / test.greenbritain.club – admin-panel
# Copy to Coolify env vars (do not commit real .env)

MONGO_URI=mongodb://your-mongo-host:27017/telegram_bot_platform
JWT_SECRET=your-super-secret-jwt-key-change-this
NODE_ENV=production

# Admin panel URL (Coolify domain)
NEXTAUTH_URL=https://admin.test.greenbritain.club

# Bot service URL for processing payouts
PYTHON_SERVICE_URL=https://bot.test.greenbritain.club

# Same key as telegram-bot-service for address decryption
ADDRESS_ENCRYPTION_KEY=your-base64-encryption-key
