# Coolify / auroneth.info – admin-panel
# Copy to Coolify env vars (do not commit real .env)

MONGO_URI=mongodb://your-mongo-host:27017/telegram_bot_platform
JWT_SECRET=your-super-secret-jwt-key-change-this
NODE_ENV=production

# Admin panel URL (Coolify domain)
NEXTAUTH_URL=https://admin.auroneth.info

# Bot service URL for processing payouts
PYTHON_SERVICE_URL=https://bot.auroneth.info

# Same key as telegram-bot-service for address decryption
ADDRESS_ENCRYPTION_KEY=your-base64-encryption-key

# Optional: auto-accept and auto-process payouts when bot owners request
# AUTO_APPROVE_PAYOUTS=true
# AUTO_APPROVE_MAX_AMOUNT=0
# AUTO_PROCESS_PAYOUTS=true
# CRON_SECRET=optional-secret-for-calling-process-approved-endpoint
