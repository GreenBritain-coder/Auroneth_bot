# Coolify / auroneth.info – telegram-bot-service
# Copy to Coolify env vars (do not commit real .env)

BOT_TOKEN=your_bot_token_from_admin_panel
PORT=8000
MONGO_URI=mongodb://your-mongo-host:27017/telegram_bot_platform

# Required for payment callbacks
WEBHOOK_URL=https://bot.auroneth.info

# SHKeeper (self-hosted, no fees - primary provider)
SHKEEPER_API_URL=https://shkeeper.auroneth.info
SHKEEPER_API_KEY=your_shkeeper_api_key
SHKEEPER_PAYOUT_USER=your_payout_username
SHKEEPER_PAYOUT_PASSWORD=your_payout_password

# CryptAPI (fallback payments)
CRYPTAPI_LTC_WALLET_ADDRESS=your_ltc_address
CRYPTAPI_BTC_WALLET_ADDRESS=your_btc_address
CRYPTAPI_ENABLED_CURRENCIES=LTC,BTC

# Platform commission rate (0.10 = 10%)
PLATFORM_COMMISSION_RATE=0.10

# Optional: same key as admin-panel for address decryption
ADDRESS_ENCRYPTION_KEY=your-base64-encryption-key
