# Coolify / test.greenbritain.club – telegram-bot-service
# Copy to Coolify env vars (do not commit real .env)

BOT_TOKEN=your_bot_token_from_admin_panel
PORT=8000
MONGO_URI=mongodb://your-mongo-host:27017/telegram_bot_platform

# Required for payment callbacks (CryptAPI, Blockonomics)
WEBHOOK_URL=https://bot.test.greenbritain.club

# CryptAPI (payments)
CRYPTAPI_LTC_WALLET_ADDRESS=your_ltc_address
CRYPTAPI_BTC_WALLET_ADDRESS=your_btc_address
CRYPTAPI_ENABLED_CURRENCIES=LTC,BTC

# Optional: same key as admin-panel for address decryption
ADDRESS_ENCRYPTION_KEY=your-base64-encryption-key
